# AI Development Platform — Environment Variables
# Copy to .env and fill in values for local development.
# These override the values in configs/app.yaml.

# Application
APP_ENV=development
APP_DEBUG=true

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_adp
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_SSL_MODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret-in-production

# OpenTelemetry (optional)
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:4317
